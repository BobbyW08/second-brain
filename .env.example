# Second Brain — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase (hosted)
# Project URL and keys from: supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI (for migrations + type generation)
# Access token from: supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Google OAuth
# Credentials from: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Also enter Client ID + Secret in: Supabase dashboard → Auth → Providers → Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic
# API key from: console.anthropic.com
ANTHROPIC_API_KEY=

# App
VITE_APP_URL=http://localhost:3000
ADMIN_EMAIL=                    # server-only — used in server functions
VITE_ADMIN_EMAIL=               # client-accessible — used in beforeLoad admin check
